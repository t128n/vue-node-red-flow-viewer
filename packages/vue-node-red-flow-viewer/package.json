{
  "name": "vue-node-red-flow-viewer",
  "version": "0.0.3",
  "description": "Vue 3 component library for rendering Node-RED flows with Vue Flow",
  "keywords": [
    "flow-based-programming",
    "flow-renderer",
    "flow-viewer",
    "node-red",
    "visual-programming",
    "vue",
    "vue-flow",
    "vue3"
  ],
  "homepage": "https://github.com/t128n/vue-node-red-flow-viewer#readme",
  "bugs": {
    "url": "https://github.com/t128n/vue-node-red-flow-viewer/issues"
  },
  "license": "Apache-2.0",
  "author": {
    "name": "Torben Haack",
    "email": "t128n@ipv4.8shield.net",
    "url": "https://t128n.dev/"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/t128n/vue-node-red-flow-viewer.git",
    "directory": "packages/vue-node-red-flow-viewer"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "NOTICE",
    "CHANGELOG.md"
  ],
  "type": "module",
  "sideEffects": [
    "./dist/style.css",
    "*.css"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "tsdown",
    "lib:build": "tsdown",
    "prepack": "pnpm run build",
    "typecheck": "vue-tsc --noEmit",
    "lint": "oxlint .",
    "format": "oxfmt . --write",
    "format:check": "oxfmt . --check",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "test:watch": "vitest",
    "changelog": "changelogen",
    "changelog:bump": "changelogen --bump"
  },
  "dependencies": {
    "@vue-flow/background": "^1.3.0",
    "@vue-flow/core": "^1.41.0"
  },
  "devDependencies": {
    "@tsdown/css": "^0.21.10",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vitest/ui": "^1.6.0",
    "@vue/test-utils": "^2.4.0",
    "changelogen": "^0.6.2",
    "jsdom": "^24.0.0",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "tsdown": "^0.21.10",
    "typescript": "^6.0.3",
    "unplugin-vue": "^7.2.0",
    "vite": "^5.0.0",
    "vitest": "^1.6.0",
    "vue": "^3.4.0",
    "vue-tsc": "^3.2.7"
  },
  "peerDependencies": {
    "vue": "^3.3.0"
  },
  "packageManager": "pnpm@9.15.9"
}
