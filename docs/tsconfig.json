{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "preserve",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "types": ["vite/client"]
  },
  "include": [".vitepress/**/*.ts", ".vitepress/**/*.vue", "**/*.md"],
  "exclude": [".vitepress/cache", ".vitepress/dist", "node_modules"]
}
